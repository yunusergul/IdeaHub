DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ideahub?schema=public"
JWT_SECRET="change-this-to-a-secure-secret-key"
JWT_REFRESH_SECRET="change-this-to-another-secure-secret-key"
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# SMTP (MailHog defaults for local development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
SMTP_FROM="IdeaHub <noreply@ideahub.local>"

# Storage (local | s3)
STORAGE_PROVIDER=local
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=ideahub-uploads
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_FORCE_PATH_STYLE=true
